# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# 老站迁移的图片（394MB），通过 rsync 部署，不入 git
/public/cycms
# 后台上传的新图片（运行时数据，不入 git）
/public/uploads
